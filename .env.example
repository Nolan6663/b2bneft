# Скопируй в .env и заполни. На VPS лежит в /var/www/neft/.env
# ВАЖНО: NODE_ENV и NODE_EXTRA_CA_CERTS живут в ecosystem.config.js (env-блок),
# НЕ здесь — Node читает их при старте процесса, plain `pm2 restart` их из .env не подхватит.

# --- Ядро ---
PORT=5000
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=change-me-long-random-string
APP_URL=https://texzakaz.ru
CORS_ORIGIN=

# --- Email (SMTP, nodemailer) ---
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@texzakaz.ru

# --- Файлы: S3/Cloudflare R2 (prod) или локально в uploads/ если пусто ---
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_REGION=auto
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=

# --- AI: генерация ТЗ/КП (lib/ai-client.js, OpenAI-compatible) ---
# Провайдер на проде: GigaChat (Sber). Groq заблокирован из РФ (403).
# Для GigaChat нужен NODE_EXTRA_CA_CERTS=certs/russian_trusted_root_ca.pem (в ecosystem.config.js).
AI_TZ_PROVIDER=gigachat
AI_TZ_API_KEY=
AI_TZ_BASE_URL=
AI_TZ_MODEL=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Легаси-фолбэки (используются, если AI_TZ_* не заданы)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
# AI-поиск поставщиков (/api/ai-search) — часто не работает из РФ
GEMINI_API_KEY=
# Отладка сырых ответов AI в логи
AI_DEBUG_RAW=

# --- Telegram-бот (telegram-bot.js) ---
# ВНИМАНИЕ: с VPS api.telegram.org недоступен (блокировка) — нужен split-tunnel
# AmneziaWG (только CIDR Телеграма через VPN). Без токена бот тихо выключен.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=

# --- Web Push (VAPID) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@texzakaz.ru

# --- OAuth Яндекс ---
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=

# --- Карты ---
MAP_PROVIDER=yandex
YANDEX_MAPS_API_KEY=

# --- Мониторинг ---
SENTRY_DSN=

# --- Реестр ГИСП: авто-инвайты заводам при новой закупке ---
# 0 = выключить (ОБЯЗАТЕЛЬНО при ручных тестах на проде — иначе письма реальным заводам!)
REGISTRY_INVITES_ENABLED=

# --- Маркетинговая рассылка заводам (scripts/outreach.js) ---
# Почта для ответов заводов (Reply-To). Без неё --send откажется работать.
OUTREACH_REPLY_TO=

# --- Сид/сервисное (только dev) ---
SEED_ADMIN=
ADMIN_EMAIL=
ADMIN_PASSWORD=
SEED_DEMO_DATA=
GEOCODE_ON_START=
