# Copy to .env and fill in values. See docs/README.md for deployment notes.

NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://user:password@localhost:5432/b2bneft
JWT_SECRET=dev-jwt-secret-change-in-development
APP_URL=http://localhost:5000

RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
CORS_ORIGIN=

# Cloudflare R2 / S3 (recommended in production)
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_REGION=auto
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=


# Sentry (error monitoring, optional)
SENTRY_DSN=
MAP_PROVIDER=yandex
YANDEX_MAPS_API_KEY=
GEMINI_API_KEY=

# AI для генерации ТЗ (OpenAI-compatible: DeepSeek, OpenAI, OpenRouter)
AI_TZ_API_KEY=
AI_TZ_BASE_URL=https://api.deepseek.com
AI_TZ_MODEL=deepseek-chat

SEED_ADMIN=true
SEED_DEMO_DATA=true
ADMIN_EMAIL=admin@platform.ru
ADMIN_PASSWORD=Admin2025

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=TexZakazBot
